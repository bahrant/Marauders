# =============================================================================
# BioReactorAgent — Secrets Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# OpenAI API key — used by gpt_agent.py for GPT-4o strategic sweeps
OPENAI_API_KEY=sk-...

# OPC-UA server password — used by opc_reader.py and opc_writer.py
# Corresponds to the username set in config.toml [opc_ua].username
OPC_UA_PASSWORD=...

# Run identifier — injected at service start (e.g. in ExecStart or via env file)
# Uniquely identifies this production run in audit.db
RUN_ID=run-001
